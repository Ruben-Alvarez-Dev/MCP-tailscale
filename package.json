{
  "name": "mcp-tailscale",
  "version": "1.0.0",
  "description": "Model Context Protocol (MCP) server for Tailscale API - Complete network management",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-tailscale": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-esm src/index.ts",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tailscale",
    "vpn",
    "network",
    "wireguard",
    "api",
    "claude",
    "llm"
  ],
  "author": "Ruben-Alvarez-Dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ruben-Alvarez-Dev/MCP-tailscale"
  },
  "bugs": {
    "url": "https://github.com/Ruben-Alvarez-Dev/MCP-tailscale/issues"
  },
  "homepage": "https://github.com/Ruben-Alvarez-Dev/MCP-tailscale#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.4",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ]
}
