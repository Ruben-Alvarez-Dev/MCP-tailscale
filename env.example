# Environment Variables Template
# Copy this file to .env and configure your credentials

# Required Configuration
# Get your API key from: https://login.tailscale.com/admin/settings/keys
TAILSCALE_API_KEY=tskey-api-xxxxxxxxxxxxx

# Your tailnet name (usually your email or organization name)
# Find it at: https://login.tailscale.com/admin/settings/general
TAILSCALE_TAILNET=your-email@example.com

# Optional Configuration
# TAILSCALE_API_URL=https://api.tailscale.com
# TAILSCALE_TIMEOUT=30000
# LOG_LEVEL=info
