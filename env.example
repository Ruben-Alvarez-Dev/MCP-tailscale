# ═══════════════════════════════════════════════════════════════════════════
# Tailscale MCP Server - Variables de Entorno
# ═══════════════════════════════════════════════════════════════════════════
# Copia este archivo a .env y configura tus credenciales

# ─────────────────────────────────────────────────────────────────────────────
# CONFIGURACIÓN OBLIGATORIA
# ─────────────────────────────────────────────────────────────────────────────

# Tu API Key de Tailscale
# Obtener en: https://login.tailscale.com/admin/settings/keys
TAILSCALE_API_KEY=tskey-api-xxxxxxxxxxxxx

# Tu Tailnet (nombre de tu red Tailscale)
# Suele ser tu email o nombre de organización
# Ver en: https://login.tailscale.com/admin/settings/general
TAILSCALE_TAILNET=your-email@example.com

# ─────────────────────────────────────────────────────────────────────────────
# CONFIGURACIÓN OPCIONAL
# ─────────────────────────────────────────────────────────────────────────────

# Base URL de la API (por defecto: https://api.tailscale.com)
# TAILSCALE_API_URL=https://api.tailscale.com

# Timeout de las peticiones en ms (por defecto: 30000)
# TAILSCALE_TIMEOUT=30000

# Log level: debug, info, warn, error (por defecto: info)
# LOG_LEVEL=info
